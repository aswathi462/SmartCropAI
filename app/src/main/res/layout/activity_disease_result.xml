<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FFF7">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/resultTopBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#4F6D46">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AgroPaddy Disease Result"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/severityArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/resultTopBar">

        <FrameLayout
            android:id="@+id/statusCircle"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@android:drawable/presence_online"> <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvSeverityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Mild Infection"
            android:textColor="#EAB308"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConfidenceBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="87%"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/severityArea">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disease Identified"
                android:textColor="#666666" />
            <TextView
                android:id="@+id/tvDiseaseName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bacterial Leaf Blight"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>