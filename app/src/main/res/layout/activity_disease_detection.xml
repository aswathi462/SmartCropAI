<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7EE">


    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#3E5F43"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disease Detection"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/upload_crop_image_title"
                        android:textColor="#1B3022"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Upload area: shows placeholder or actual image -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:background="@drawable/dashed_border"
                        android:clipToOutline="true">

                        <!-- Placeholder (when no image selected) -->
                        <LinearLayout
                            android:id="@+id/uploadPlaceholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_upload_leaf" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/upload_instructions"
                                android:textAlignment="center"
                                android:textColor="#85AB85"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Actual image preview (hidden until image selected) -->
                        <ImageView
                            android:id="@+id/ivImagePreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/upload_crop_image_title"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                    </FrameLayout>

                    <!-- "Tap to change" hint after image selected -->
                    <TextView
                        android:id="@+id/tvTapToChange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/tap_to_change"
                        android:textColor="#85AB85"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <!-- Invalid image error banner -->
                    <TextView
                        android:id="@+id/tvInvalidImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#FFF3F3"
                        android:padding="12dp"
                        android:text="@string/invalid_image_error"
                        android:textColor="#C0392B"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Camera + Gallery buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCamera"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/btn_camera"
                            android:textColor="#3E5F43"
                            app:cornerRadius="12dp"
                            app:strokeColor="#3E5F43"
                            app:strokeWidth="1.5dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGallery"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/btn_gallery"
                            android:textColor="#3E5F43"
                            app:cornerRadius="12dp"
                            app:strokeColor="#3E5F43"
                            app:strokeWidth="1.5dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== CROP DETAILS CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="#4F6D46"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/lblVariety"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Select Paddy Variety"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnBack" />

            <Spinner
                android:id="@+id/spinnerVariety"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lblVariety" />

            <TextView
                android:id="@+id/lblSymptoms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Describe Symptoms"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spinnerVariety" />

            <EditText
                android:id="@+id/etSymptoms"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginHorizontal="24dp"
                android:hint="e.g. Yellow spots..."
                android:gravity="top"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lblSymptoms" />

            <FrameLayout
                android:id="@+id/uploadArea"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="#E8F0E8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etSymptoms">
                <ImageView
                    android:id="@+id/ivUploadIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera" />
                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSubmit"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#4F6D46"
                android:text="Analyze Crop"
                android:textColor="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/uploadArea" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>