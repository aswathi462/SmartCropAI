<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F9F4"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Predicted Rice Yield"
        android:textSize="18sp"
        android:textColor="#4F6D46"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/tvYieldValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.46 tons/hectare"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1B3022"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="10dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suggestions to Improve Yield:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1B3022"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="- Apply urea fertilizer to increase nitrogen.\n- Apply DAP fertilizer for root development."
        android:textSize="16sp"
        android:lineSpacingExtra="8dp"
        android:textColor="#444444" />

    <Button
        android:id="@+id/btnResultBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:text="Back to Form"
        android:backgroundTint="#4F6D46"
        android:textColor="#FFFFFF" />
</LinearLayout>