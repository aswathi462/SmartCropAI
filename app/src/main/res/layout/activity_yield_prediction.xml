<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7EE">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/yieldTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#3E5F43"
        android:elevation="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnYieldToHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yield Prediction"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnYieldToHome"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MAIN CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/yieldTopBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Paddy Variety"
                android:textStyle="bold"
                android:textColor="#1B3022" />

            <Spinner
                android:id="@+id/spinnerYieldVariety"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp" />

            <!-- NPK CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soil Nutrients (NPK)"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etN"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Nitrogen (N)"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="10dp"/>

                    <EditText
                        android:id="@+id/etP"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Phosphorus (P)"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="8dp"/>

                    <EditText
                        android:id="@+id/etK"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Potassium (K)"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WEATHER CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etRain"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Rainfall (mm)"
                        android:inputType="numberDecimal"/>

                    <EditText
                        android:id="@+id/etPH"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="pH Value"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="8dp"/>

                    <EditText
                        android:id="@+id/etHum"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Humidity (%)"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnPredictYield"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#4F6D46"
                android:text="Predict Yield"
                android:textColor="#FFFFFF" />

            <!-- LOADING -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>