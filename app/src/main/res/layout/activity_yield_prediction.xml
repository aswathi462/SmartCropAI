<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7EE">

    <LinearLayout
        android:id="@+id/topBarYield"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#3E5F43"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackYield"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/yield_page_title"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBarYield">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="20dp"
            android:paddingEnd="18dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:text="@string/yield_page_subtitle"
                android:textColor="#5A7A60"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/crop_profile"
                        android:textColor="#1B3022"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/select_paddy_variety"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerYieldVariety"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/field_conditions"
                        android:textColor="#1B3022"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/nitrogen_n"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etNitrogen"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_nitrogen"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/phosphorus_p"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etPhosphorus"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_phosphorus"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/potassium_k"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etPotassium"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_potassium"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/temperature_c"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etTemperature"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_temperature"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/humidity_percent"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etHumidity"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_humidity"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/soil_ph"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etSoilPh"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_soil_ph"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/rainfall_mm"
                        android:textColor="#4F6D46"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etRainfall"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_field_light"
                        android:hint="@string/hint_rainfall"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1B3022"
                        android:textColorHint="#6F7D73" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPredictYield"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/predict_yield_now"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#3E5F43"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>